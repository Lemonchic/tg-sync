<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen ride data field for the Karoo 2 (480×800 max).
     Three weighted zones: playlist header, track title, playback controls. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/field_background"
    android:orientation="vertical"
    android:gravity="center">

    <!-- ── Playlist area (weight 1) ── -->
    <RelativeLayout
        android:id="@+id/playlist_area"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/field_button_background"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/playlist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:ellipsize="end"
            android:gravity="center"
            android:singleLine="true"
            android:text="@string/playlist_none"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Thin divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ── Track title area (weight 3) ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="96dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="3"
            android:text="@string/track_no_music"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Thin divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ── Control buttons (weight 2) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Shuffle -->
        <FrameLayout
            android:id="@+id/btn_shuffle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/field_button_background"
            android:contentDescription="@string/cd_shuffle">

            <ImageView
                android:id="@+id/ic_shuffle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shuffle"
                android:tint="@color/control_inactive"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- Previous -->
        <FrameLayout
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/field_button_background"
            android:contentDescription="@string/cd_previous">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_previous"
                android:tint="@color/text_primary"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- Play / Pause -->
        <FrameLayout
            android:id="@+id/btn_play_pause"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/field_button_background"
            android:contentDescription="@string/cd_play_pause">

            <ImageView
                android:id="@+id/ic_play_pause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:tint="@color/text_primary"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- Next -->
        <FrameLayout
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/field_button_background"
            android:contentDescription="@string/cd_next">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_next"
                android:tint="@color/text_primary"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- Repeat -->
        <FrameLayout
            android:id="@+id/btn_repeat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/field_button_background"
            android:contentDescription="@string/cd_repeat">

            <ImageView
                android:id="@+id/ic_repeat"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_repeat"
                android:tint="@color/control_inactive"
                android:contentDescription="@null" />
        </FrameLayout>
    </LinearLayout>

</LinearLayout>
