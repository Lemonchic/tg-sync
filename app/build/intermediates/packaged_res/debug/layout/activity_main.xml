<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ════════════════════════════════════════════════ -->
        <!-- App Header                                       -->
        <!-- ════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_music_note"
                android:contentDescription="@string/app_name"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/extension_name"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            style="@style/Divider"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- ════════════════════════════════════════════════ -->
        <!-- Section 1: Bot Setup                             -->
        <!-- ════════════════════════════════════════════════ -->
        <TextView
            style="@style/SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_bot_setup" />

        <!-- Bot status indicator -->
        <TextView
            android:id="@+id/tv_bot_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="@string/bot_not_configured"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp" />

        <!-- Token input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_bot_token"
            style="@style/DarkOutlinedInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_bot_token"
            app:endIconMode="password_toggle"
            app:boxStrokeColor="@color/input_stroke"
            app:hintTextColor="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_bot_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Validate button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_validate"
            style="@style/SecondaryButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="@string/btn_validate" />

        <!-- Divider -->
        <View
            style="@style/Divider"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- ════════════════════════════════════════════════ -->
        <!-- Section 2: Channels                              -->
        <!-- ════════════════════════════════════════════════ -->
        <TextView
            style="@style/SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_channels" />

        <!-- Channel input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_channel"
                style="@style/DarkOutlinedInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_channel_username"
                app:boxStrokeColor="@color/input_stroke"
                app:hintTextColor="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_channel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_channel"
                style="@style/PrimaryButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="@string/btn_add_channel"
                android:enabled="false" />
        </LinearLayout>

        <!-- No channels placeholder -->
        <TextView
            android:id="@+id/tv_no_channels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="@string/no_channels_configured"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp" />

        <!-- Channel list container (dynamic children added programmatically) -->
        <LinearLayout
            android:id="@+id/channel_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />

        <!-- Divider -->
        <View
            style="@style/Divider"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- ════════════════════════════════════════════════ -->
        <!-- Section 3: Sync                                  -->
        <!-- ════════════════════════════════════════════════ -->
        <TextView
            style="@style/SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_sync" />

        <!-- Storage info -->
        <TextView
            android:id="@+id/tv_storage_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="@string/storage_unknown"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/pb_storage"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:layout_marginBottom="12dp" />

        <!-- Sync button (big, prominent) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sync"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_sync_now"
            android:textSize="16sp"
            android:textStyle="bold"
            android:enabled="false" />

        <!-- Sync disabled reason -->
        <TextView
            android:id="@+id/tv_sync_disabled_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="4dp"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Sync progress section (hidden by default) -->
        <LinearLayout
            android:id="@+id/sync_progress_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/pb_sync"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/tv_sync_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:text="@string/sync_starting"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- Scroll log area for per-file results -->
            <ScrollView
                android:id="@+id/sv_sync_log"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="8dp"
                android:background="@color/surface"
                android:padding="8dp"
                android:scrollbars="vertical"
                android:fadingEdge="vertical"
                android:requiresFadingEdge="vertical">

                <TextView
                    android:id="@+id/tv_sync_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp" />
            </ScrollView>
        </LinearLayout>

        <!-- Divider -->
        <View
            style="@style/Divider"
            android:layout_width="match_parent"
            android:layout_height="1dp" />

        <!-- ════════════════════════════════════════════════ -->
        <!-- Section 4: About                                 -->
        <!-- ════════════════════════════════════════════════ -->
        <TextView
            style="@style/SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_about" />

        <TextView
            android:id="@+id/tv_about_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_about_tracks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_about_playlists"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_about_storage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_data"
            style="@style/DestructiveButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:text="@string/btn_clear_all_data" />

    </LinearLayout>
</ScrollView>
